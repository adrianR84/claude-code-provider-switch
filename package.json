{
  "name": "claude-code-provider-switch",
  "version": "1.0.0",
  "description": "Cross-platform Claude Code settings switcher with OpenRouter support",
  "main": "lib/config.js",
  "bin": {
    "claude-switch": "./bin/claude-switch.js"
  },
  "scripts": {
    "start": "node bin/claude-switch.js",
    "dev": "node bin/claude-switch.js",
    "install-global": "npm install -g .",
    "link": "npm link",
    "unlink": "npm unlink -g claude-code-provider-switch",
    "test": "node test/test-validation-errors.js",
    "test:validation": "node test/test-validation-errors.js",
    "test:provider": "node test/test-ollama-provider.js",
    "test:comprehensive": "node test/test-comprehensive.js",
    "test:all": "node test/run-tests.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "openrouter",
    "switcher",
    "cli"
  ],
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "bin/",
    "lib/",
    "README.md",
    ".env"
  ],
  "preferGlobal": true
}
